generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String            @id @default(cuid())
  name           String?
  email          String?           @unique
  emailVerified  Boolean           @default(false)
  image          String?
  accounts       Account[]
  sessions       Session[]
  journals       UserJournal[]
  voiceSubmits   VoiceSubmission[]
  contactSubmits ContactSubmission[]
  createdArticles Article[]
  createdResources ResourceOfMonth[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  accountId          String
  providerId         String
  accessToken        String? @db.Text
  refreshToken       String? @db.Text
  idToken            String? @db.Text
  accessTokenExpiresAt DateTime?
  refreshTokenExpiresAt DateTime?
  scope              String?
  password           String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  expiresAt    DateTime
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, value])
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String   @db.Text
  createdAt DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
}

model VoiceSubmission {
  id         String   @id @default(cuid())
  title      String
  reflection String   @db.Text
  author     String
  visibility String
  descriptor String?
  status     String   @default("pending")
  isVoiceOfWeek Boolean @default(false)
  approvedAt DateTime?
  createdAt  DateTime @default(now())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([isVoiceOfWeek])
}

model UserJournal {
  id           String   @id @default(cuid())
  answer       String   @db.Text
  stressLevel  String
  prompt       String
  resultTone   String
  resultTitle  String
  resultMessage String  @db.Text
  createdAt    DateTime @default(now())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model CachedQuote {
  id              String   @id @default(cuid())
  theme           String
  answerSignature String
  text            String   @db.Text
  author          String?
  source          String
  expiresAt       DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([theme, answerSignature])
  @@index([expiresAt])
}

model Article {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  excerpt         String   @db.Text
  content         Json
  author          String
  imageSrc        String
  imageAlt        String
  reflectionMoment String  @db.Text
  isFeatured      Boolean  @default(false)
  status          String   @default("published")
  publishedAt     DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdById     String?
  createdBy       User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([status, publishedAt])
  @@index([isFeatured, publishedAt])
}

model ResourceOfMonth {
  id          String   @id @default(cuid())
  monthKey    String   @unique
  title       String
  description String   @db.Text
  linkUrl     String?
  linkLabel   String?
  status      String   @default("draft")
  isCurrent   Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([status, monthKey])
  @@index([isCurrent])
}
