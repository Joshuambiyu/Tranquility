generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String            @id @default(cuid())
  name           String?
  email          String?           @unique
  emailVerified  DateTime?
  image          String?
  accounts       Account[]
  sessions       Session[]
  journals       UserJournal[]
  voiceSubmits   VoiceSubmission[]
  contactSubmits ContactSubmission[]
  createdArticles Article[]
  createdResources ResourceOfMonth[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String   @db.Text
  createdAt DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
}

model VoiceSubmission {
  id         String   @id @default(cuid())
  title      String
  reflection String   @db.Text
  author     String
  visibility String
  descriptor String?
  status     String   @default("pending")
  isVoiceOfWeek Boolean @default(false)
  approvedAt DateTime?
  createdAt  DateTime @default(now())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([isVoiceOfWeek])
}

model UserJournal {
  id           String   @id @default(cuid())
  answer       String   @db.Text
  stressLevel  String
  prompt       String
  resultTone   String
  resultTitle  String
  resultMessage String  @db.Text
  createdAt    DateTime @default(now())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model CachedQuote {
  id              String   @id @default(cuid())
  theme           String
  answerSignature String
  text            String   @db.Text
  author          String?
  source          String
  expiresAt       DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([theme, answerSignature])
  @@index([expiresAt])
}

model Article {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  excerpt         String   @db.Text
  content         Json
  author          String
  imageSrc        String
  imageAlt        String
  reflectionMoment String  @db.Text
  isFeatured      Boolean  @default(false)
  status          String   @default("published")
  publishedAt     DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdById     String?
  createdBy       User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([status, publishedAt])
  @@index([isFeatured, publishedAt])
}

model ResourceOfMonth {
  id          String   @id @default(cuid())
  monthKey    String   @unique
  title       String
  description String   @db.Text
  linkUrl     String?
  linkLabel   String?
  status      String   @default("draft")
  isCurrent   Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([status, monthKey])
  @@index([isCurrent])
}
